---
layout: base.njk
title: Hello
description: I am Jurre, an engineer with a passion for cool stuff.
---
<section class="hero">
  <img src="{{ site.avatar }}" alt="{{ site.title }}">
  <h1>Hello</h1>
  <p>{{ site.tagline }}</p>
  <ul class="hero-meta">
    <li>
      <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="2" y="7" width="20" height="14" rx="2"></rect>
        <path d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
      </svg>
      <span>{{ site.role }} at {{ site.company }}</span>
    </li>
    <li>
      <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0z"></path>
        <circle cx="12" cy="10" r="3"></circle>
      </svg>
      <span>Living in {{ site.location }}</span>
    </li>
  </ul>
</section>

<h2 class="section-title">Recent posts</h2>
<ul class="post-list">
  {% for post in collections.posts | reverse %}
  <li>
    <a href="{{ post.url }}">
      <span class="title">{{ post.data.title }}</span>
      <span class="date">{{ post.date | readableDate }} · {{ post.data.readTime }}</span>
    </a>
  </li>
  {% endfor %}
</ul>
